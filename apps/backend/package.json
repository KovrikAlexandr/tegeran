{
  "name": "@tegeran/backend",
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:status": "prisma migrate status",
    "start": "node dist/main.js",
    "start:dev": "tsx src/main.ts",
    "test": "jest --runInBand --testPathIgnorePatterns='auth.integration.spec.ts|frontend-scenarios.integration.spec.ts'",
    "test:auth:integration": "jest --runInBand --runTestsByPath src/test/auth.integration.spec.ts",
    "test:frontend:integration": "jest --runInBand --runTestsByPath src/test/frontend-scenarios.integration.spec.ts"
  },
  "dependencies": {
    "@nestjs/common": "11.1.7",
    "@nestjs/core": "11.1.7",
    "@nestjs/platform-express": "11.1.7",
    "@prisma/client": "6.19.3",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.2",
    "dotenv": "17.2.3",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2"
  },
  "devDependencies": {
    "@types/express": "5.0.3",
    "@types/jest": "30.0.0",
    "@types/node": "24.6.1",
    "@types/supertest": "6.0.3",
    "@nestjs/testing": "11.1.7",
    "jest": "30.2.0",
    "prisma": "6.19.3",
    "supertest": "7.1.4",
    "ts-jest": "29.4.5",
    "tsx": "4.20.6",
    "typescript": "5.9.3"
  }
}
