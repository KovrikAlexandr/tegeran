    {
      "name": "13 Get Group Chat Members",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{accessTokenA}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{apiBaseUrl}}/chats/{{groupChatId}}/members",
          "host": [
            "{{apiBaseUrl}}"
          ],
